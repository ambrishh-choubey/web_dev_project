
def selection_sort(nums):
# nums=[5,7,8,9,4,2,5]
    n=len(nums)
    for i in range(len(nums)):
        mini_ind=i
        for j in range(i+1,n):
            if nums[j]<nums[mini_ind]:
                mini_ind=j
        nums[i],nums[mini_ind]=nums[mini_ind],nums[i]
        return
result=selection_sort([5,7,8,9,4,2,5])
print(result)
